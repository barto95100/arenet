		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.1",
		"@xyflow/svelte": "^1.6.0",
		"d3": "^7.9.0",
		"flag-icons": "^7.5.0",
		"topojson-client": "^3.1.0"
	}
}
